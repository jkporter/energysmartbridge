        "mqtt": "^5.10.3",
        "pino": "^9.6.0"
    },
    "devDependencies": {
        "@types/body-parser": "^1.19.6",
        "@types/express": "^5.0.6",
        "@types/node": "^25.6.0",
        "typescript": "^6.0.2"
    }
